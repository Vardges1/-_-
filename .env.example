# --- Database (required) ---
# Example matches docker-compose.yml defaults (user/password/db: taskmanager).
DATABASE_URL="postgresql://taskmanager:taskmanager@localhost:5432/taskmanager?schema=public"

# --- Optional: LLM (OpenAI-compatible) ---
# AI routes return 503 SERVICE_UNAVAILABLE when LLM_API_KEY is empty or unset.
# The app supports any OpenAI-compatible provider via LLM_BASE_URL.
LLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"
# LLM_BASE_URL="https://api.openai.com/v1"
